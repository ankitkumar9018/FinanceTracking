# ============================================================
# FinanceTracker Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values you need.
# All values shown below are defaults — only override what you
# need to change.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=FinanceTracker
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO
API_PORT=8000

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Token expiration (minutes / days)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────
# SQLite (default, development):
DATABASE_URL=sqlite+aiosqlite:///./finance.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/financetracker
# DATABASE_POOL_SIZE=5

# ── Redis (optional — app works without it) ──────────────────
REDIS_URL=redis://localhost:6379

# ── Market Data ──────────────────────────────────────────────
PRICE_REFRESH_INTERVAL=5
DEFAULT_CHART_DAYS=30

# Market hours (used to schedule price fetching)
# MARKET_HOURS_IN=09:15-15:30
# MARKET_HOURS_DE=09:00-17:30

# ── Email Notifications (SendGrid) ───────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=

# ── SMS / WhatsApp (Twilio) ──────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI / LLM ────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Broker APIs ──────────────────────────────────────────────
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ICICI_APP_KEY=
ICICI_SECRET_KEY=

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:1420,https://tauri.localhost

# ── Mutual Funds ───────────────────────────────────────────
MFAPI_URL=https://api.mfapi.in

# ── Notification Channels ──────────────────────────────────
# Comma-separated list of enabled channels: in_app,email,telegram,whatsapp,sms
NOTIFICATION_CHANNELS=in_app

# ── Display Defaults ─────────────────────────────────────────
DEFAULT_CURRENCY=INR
DEFAULT_THEME=dark
ALERT_CHECK_INTERVAL=60
